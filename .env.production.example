# Production env — paste into Render / Vercel dashboards, not committed.

# === API (Render) ===
NODE_ENV=production
PORT=10000                                          # Render convention
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/lms
JWT_SECRET=                                         # generate with: openssl rand -base64 48
JWT_EXPIRES_IN=7d
GEMINI_API_KEY=                                     # from aistudio.google.com/app/apikey
CORS_ORIGINS=https://your-app.vercel.app            # comma-separated if multiple

# === Web (Vercel) ===
VITE_API_URL=https://lms-api.onrender.com
