# API
PORT=5000
NODE_ENV=development

# MongoDB — free M0 Atlas cluster recommended (mongodb.com/cloud/atlas)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.mongodb.net/lms?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# AI — Google Gemini free tier (aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Frontend
VITE_API_URL=http://localhost:5000
